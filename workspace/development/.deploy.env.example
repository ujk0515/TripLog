# TripLog Frontend Deploy 설정
# 이 파일을 .deploy.env 로 복사한 뒤 값을 채워 넣으세요.
# .deploy.env 는 gitignore 되어 있습니다.

# 오라클 서버 공인 IP
DEPLOY_HOST=168.107.9.117

# SSH 접속 유저 (Oracle Ubuntu 기본: ubuntu)
DEPLOY_USER=ubuntu

# SSH 개인키 경로 (오라클 다운로드한 .key 파일)
DEPLOY_KEY=~/.ssh/oracle-triplog.key

# 서버 내 프론트 배포 경로 (Nginx 가 서빙할 위치)
DEPLOY_PATH=/var/www/triplog
